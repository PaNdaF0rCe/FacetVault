{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://gfacetvault.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://gfacetvault.firebaseapp.com/__/firebase/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/update-rates",
      "schedule": "0 18 * * *"
    }
  ]
}