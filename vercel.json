{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://gfacetvault.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://gfacetvault.firebaseapp.com/__/firebase/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/update-rates",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/trigger-daily-draft",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/wake-bot",
      "schedule": "25 13 * * 1-5"
    },
    {
      "path": "/api/wake-bot",
      "schedule": "55 12 * * 0,6"
    }
  ]
}